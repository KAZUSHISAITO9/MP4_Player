<Window x:Class="MP4_Player.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MP4 Player" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="動画ファイルが見つかりません" 
                       FontSize="24" 
                       Foreground="#333333"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>
            <TextBlock Text="フォルダを選択してください" 
                       FontSize="16" 
                       Foreground="#666666"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>
            <Button Content="フォルダを選択" 
                    Click="SelectFolderButton_Click"
                    Width="200"
                    Height="50"
                    FontSize="16"
                    Background="#4CAF50"
                    Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
